# ─────────────────────────────────────────────────────────────
# PATH OF THE IMMORTAL — Environment Variables
# 1. Copy this file:  cp .env.example .env
# 2. Fill in every value below
# 3. NEVER commit .env to GitHub
# ─────────────────────────────────────────────────────────────

# PostgreSQL — get a free DB at https://supabase.com or https://neon.tech
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=postgresql://postgres:yourpassword@localhost:5432/pathoftheimmortal

# Discord OAuth2
# Steps: discord.com/developers → New App → OAuth2 tab
# Add redirect: http://localhost:8000/auth/callback (dev)  |  https://yourdomain.com/auth/callback (prod)
DISCORD_CLIENT_ID=your_discord_client_id
DISCORD_CLIENT_SECRET=your_discord_client_secret
DISCORD_REDIRECT_URI=http://localhost:8000/auth/callback

# Discord Bot Token
# Steps: discord.com/developers → Your App → Bot tab → Reset Token
DISCORD_BOT_TOKEN=your_bot_token_here

# Midtrans — dashboard.midtrans.com → Settings → Access Keys
# Use SB- (Sandbox) keys while testing, Mid- keys when going live
MIDTRANS_SERVER_KEY=SB-Mid-server-xxxxxxxxxxxxxxxx
MIDTRANS_CLIENT_KEY=SB-Mid-client-xxxxxxxxxxxxxxxx
MIDTRANS_IS_PROD=false

# JWT Secret — run this to generate:
# python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=replace_with_a_long_random_string

# URLs
FRONTEND_URL=http://localhost:5500   # or http://127.0.0.1:5500 if using VS Code Live Server
BACKEND_URL=http://localhost:8000
